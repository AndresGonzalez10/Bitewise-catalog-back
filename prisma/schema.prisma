generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// 🍎 Entidad Ingrediente (Dueño: Servicio de Catálogo)
model Ingredient {
  id             Int      @id @default(autoincrement())
  author_id      String?  @db.Uuid
  name           String   @unique @db.VarChar(100)
  category       String   @db.VarChar(50)
  unit_price     Decimal  @default(0) @db.Decimal(10, 4)
  unit_default   String   @default("g") @db.VarChar(10)

  recipe_items   RecipeIngredient[]
  author         User?    @relation(fields: [author_id], references: [id], onDelete: Cascade)

  @@map("ingredients")
}

// 🍲 Entidad Receta (Dueño: Servicio de Catálogo)
model Recipe {
  id           Int      @id @default(autoincrement())
  title        String   @db.VarChar(200)
  instructions String
  image_url    String?
  is_custom    Boolean? @default(false)
  author_id    String?  @db.Uuid
  created_at   DateTime? @default(now()) @db.Timestamp(6)

  ingredients  RecipeIngredient[]
  author       User?    @relation(fields: [author_id], references: [id], onDelete: Cascade)

  @@map("recipes")
}

// 🔗 Tabla Intermedia Receta-Ingrediente
model RecipeIngredient {
  recipe_id         Int
  ingredient_id     Int
  required_quantity Decimal @db.Decimal(10, 2)

  recipe            Recipe     @relation(fields: [recipe_id], references: [id], onDelete: Cascade)
  ingredient        Ingredient @relation(fields: [ingredient_id], references: [id])

  @@id([recipe_id, ingredient_id])
  @@map("recipe_ingredients")
}

// 👤 Modelo "Espejo" de Usuario (Solo para mantener la relación de las llaves foráneas)
model User {
  id          String       @id @db.Uuid
  ingredients Ingredient[]
  recipes     Recipe[]

  @@map("users")
}