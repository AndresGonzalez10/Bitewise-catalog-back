generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Ingredient {
  id              Int                @id @default(autoincrement())
  author_id       String?            @db.Uuid
  name            String             @unique @db.VarChar(100)
  category        String             @db.VarChar(50)
  unit_price      Decimal            @default(0) @db.Decimal(10, 4)
  unit_default    String             @default("g") @db.VarChar(10)
  weight_per_unit Decimal            @default(1.00) @db.Decimal(10, 2) 

  recipe_items    RecipeIngredient[]
  author          User?              @relation(fields: [author_id], references: [id], onDelete: Cascade)

  @@map("ingredients")
}


model Recipe {
  id           Int       @id @default(autoincrement())
  title        String    @db.VarChar(200)
  instructions String
  image_url    String?
  is_custom    Boolean?  @default(false)
  author_id    String?   @db.Uuid
  servings     String?   @default("1-2") @db.VarChar(10) 
  created_at   DateTime? @default(now()) @db.Timestamp(6)

  ingredients  RecipeIngredient[]
  author       User?     @relation(fields: [author_id], references: [id], onDelete: Cascade)

  @@map("recipes")
}


model RecipeIngredient {
  recipe_id         Int
  ingredient_id     Int
  required_quantity Decimal @db.Decimal(10, 2)

  recipe            Recipe     @relation(fields: [recipe_id], references: [id], onDelete: Cascade)
  ingredient        Ingredient @relation(fields: [ingredient_id], references: [id])

  @@id([recipe_id, ingredient_id])
  @@map("recipe_ingredients")
}

model User {
  id          String       @id @db.Uuid
  ingredients Ingredient[]
  recipes     Recipe[]

  @@map("users")
}

model Inventory {
  id               Int      @id @default(autoincrement())
  user_id          String?  @db.Uuid
  ingredient_id    Int?
  current_quantity Decimal  @default(0) @db.Decimal(10, 2)
  updated_at       DateTime? @default(now()) @db.Timestamp(6)

  @@unique([user_id, ingredient_id])
  @@map("inventory") // 👈 Asegúrate de que esto esté en minúsculas
}